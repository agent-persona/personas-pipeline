# Copy to .env and fill in your keys

# Provider selection for synthesis + temp sweep + baseline scripts.
# Supported:
#   anthropic -> Claude SDK
#   gemini    -> Gemini OpenAI-compatible endpoint
#   kimi      -> Kimi OpenAI-compatible endpoint
#   zai       -> Z.AI Anthropic-compatible endpoint
#   minimax   -> MiniMax Anthropic-compatible endpoint
MODEL_PROVIDER=anthropic

# Optional override for judge runs. Leave blank to reuse MODEL_PROVIDER.
JUDGE_PROVIDER=
PERSONA_SCHEMA_VERSION=v1
PERSONA_BIRTH_YEAR=1988
PERSONA_EVAL_YEAR=2026

# Anthropic / Claude
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# Pick one of: claude-haiku-4-5-20251001 (cheap, default),
#              claude-sonnet-4-6 (mid), claude-opus-4-6 (premium)
# Used by synthesis, the twin runtime, and any LLM-as-judge in evaluation/.
default_model=claude-haiku-4-5-20251001
premium_model=claude-opus-4-6
JUDGE_MODEL=
TWIN_MODEL=

# Gemini via OpenAI compatibility:
# https://ai.google.dev/gemini-api/docs/openai
GEMINI_API_KEY_MAX=
GEMINI_API_KEY_TURKEY=
GEMINI_API_KEY_SELECTOR=max
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Kimi via OpenAI compatibility:
# https://api.moonshot.ai/v1
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1

# Z.AI via Anthropic compatibility
Z_AI_GLM_API_KEY=
Z_AI_ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic

# MiniMax via Anthropic compatibility
MINIMAX_API_KEY=
MINIMAX_ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic

# Postgres (optional — the pipeline writes personas to output/ when not set)
DATABASE_URL=postgresql+asyncpg://localhost:5432/personas

# Pinecone (optional — skipped if not set, needed for embedding search)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=personas

# Voyage AI embeddings (optional — returns zero vectors if not set)
VOYAGE_API_KEY=
